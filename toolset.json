{
	"schemaVersion": "1.0",
	"swiftCompiler": {
		"extraCLIOptions": [
			"-enable-experimental-feature", "Embedded",
			"-enable-experimental-feature", "Volatile",
			"-Xfrontend", "-no-allocations",
			"-Xfrontend", "-function-sections",
			"-Xfrontend", "-disable-stack-protector",
			"-Xlinker-driver", "-nostdlib",
			"-Xlinker-driver", "-fuse-ld=lld"
		]
	},
	"linker": {
		"extraCLIOptions": [
			"-nostdlib",
			"-static",
			"--gc-sections",
			"--strip-all",
			"--orphan-handling=error",
			"-T", "linker.ld",
			"-Map", ".build/kernel.map"
		]
	},
	"debugger": {
		"path": "/usr/bin/env",
		"extraCLIOptions": [
			"qemu-system-aarch64",
			"-machine", "virt",
			"-cpu", "cortex-a57",
			"-nographic",
			"-kernel",
		]
	}
}
